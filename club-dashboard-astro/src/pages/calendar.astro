---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { requireAuth } from '../lib/auth';
import { supabaseAdmin } from '../lib/supabase';

const user = await requireAuth(Astro.request, Astro.response.headers, Astro.redirect);
const isOfficer = ['admin', 'treasurer'].includes(user.role);

const { data: events } = await supabaseAdmin
  .from('events')
  .select('id, title, start_time, end_time, location, category, status')
  .eq('status', 'active')
  .order('start_time', { ascending: true });

const eventsJson = JSON.stringify(events ?? []);
---
<DashboardLayout title="Event Calendar" user={user}>

  <div class="cal-header">
    <div class="cal-month" id="cal-month-label"></div>
    <div style="display:flex;gap:8px;align-items:center">
      {isOfficer && (
        <button class="add-btn" id="open-event-modal" style="margin-bottom:0">+ New Event</button>
      )}
      <div class="cal-nav">
        <button class="cal-btn" id="prev-month">&#8249;</button>
        <button class="cal-btn" id="next-month">&#8250;</button>
      </div>
    </div>
  </div>

  <div class="cal-grid" id="cal-grid"></div>

  <div class="events-section">
    <div class="section-label">Upcoming</div>
    <div id="upcoming-list"></div>
  </div>

  <!-- QR Modal -->
  <div class="modal-overlay hidden" id="qr-modal">
    <div class="modal-card">
      <div class="modal-title" id="modal-event-title"></div>
      <div class="modal-sub">Scan to check in</div>
      <img class="modal-qr" id="modal-qr-img" src="" alt="QR Code" />
      <button class="modal-close" id="modal-close-btn">Close</button>
    </div>
  </div>

  <!-- New Event Modal (officer only) -->
  {isOfficer && (
    <div class="form-modal hidden" id="event-modal">
      <div class="form-card">
        <div class="form-card-title">Create Event</div>
        <div class="form-row">
          <label class="form-label">Title *</label>
          <input class="form-input" id="ev-title" placeholder="e.g. Weekly Meeting" />
        </div>
        <div class="form-row">
          <label class="form-label">Description</label>
          <textarea class="form-textarea" id="ev-desc" placeholder="Optional details…" rows="2"></textarea>
        </div>
        <div class="form-row-2">
          <div class="form-row" style="margin-bottom:0">
            <label class="form-label">Start *</label>
            <input class="form-input" id="ev-start" type="datetime-local" />
          </div>
          <div class="form-row" style="margin-bottom:0">
            <label class="form-label">End</label>
            <input class="form-input" id="ev-end" type="datetime-local" />
          </div>
        </div>
        <div class="form-row-2">
          <div class="form-row" style="margin-bottom:0">
            <label class="form-label">Location</label>
            <input class="form-input" id="ev-location" placeholder="e.g. Room 201" />
          </div>
          <div class="form-row" style="margin-bottom:0">
            <label class="form-label">Type</label>
            <select class="form-select" id="ev-category">
              <option value="meeting">Meeting</option>
              <option value="event">Event</option>
              <option value="deadline">Deadline</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <label class="form-label">Check-in Password (optional)</label>
          <input class="form-input" id="ev-password" placeholder="Members enter this to check in" />
        </div>
        <div class="form-error hidden" id="ev-error"></div>
        <div class="form-actions">
          <button class="form-cancel" id="close-event-modal">Cancel</button>
          <button class="form-submit" id="submit-event">Create</button>
        </div>
      </div>
    </div>
  )}

</DashboardLayout>

<script define:vars={{ eventsJson, isOfficer }}>
let EVENTS = JSON.parse(eventsJson).map(e => ({
  ...e,
  date: e.start_time ? e.start_time.split('T')[0] : null,
  time: e.start_time
    ? new Date(e.start_time).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) +
      (e.location ? ' · ' + e.location : '')
    : '',
  type: e.category || 'meeting',
}));

const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const dows = ['Su','Mo','Tu','We','Th','Fr','Sa'];
const today = new Date();
let viewYear = today.getFullYear();
let viewMonth = today.getMonth();

function renderCalendar() {
  const firstDay = new Date(viewYear, viewMonth, 1).getDay();
  const daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();
  document.getElementById('cal-month-label').textContent = months[viewMonth] + ' ' + viewYear;

  const grid = document.getElementById('cal-grid');
  grid.innerHTML = '';

  dows.forEach(d => {
    const el = document.createElement('div');
    el.className = 'cal-dow';
    el.textContent = d;
    grid.appendChild(el);
  });

  const prevDays = new Date(viewYear, viewMonth, 0).getDate();
  for (let i = firstDay - 1; i >= 0; i--) {
    const el = document.createElement('div');
    el.className = 'cal-day other-month';
    el.innerHTML = `<div class="day-num">${prevDays - i}</div>`;
    grid.appendChild(el);
  }

  for (let d = 1; d <= daysInMonth; d++) {
    const el = document.createElement('div');
    el.className = 'cal-day';
    const ds = `${viewYear}-${String(viewMonth + 1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const isToday = d === today.getDate() && viewMonth === today.getMonth() && viewYear === today.getFullYear();
    if (isToday) el.classList.add('today');

    const dayEvents = EVENTS.filter(e => e.date === ds);
    let html = `<div class="day-num">${d}</div>`;
    dayEvents.forEach(e => {
      const type = ['meeting','event','deadline'].includes(e.type) ? e.type : 'meeting';
      html += `<div class="ev ${type}" data-id="${e.id}" data-title="${e.title}">${e.title}</div>`;
    });
    el.innerHTML = html;

    el.querySelectorAll('.ev').forEach(chip => {
      chip.addEventListener('click', async (ev) => {
        ev.stopPropagation();
        await openQRModal(chip.dataset.id, chip.dataset.title);
      });
    });

    grid.appendChild(el);
  }

  const totalCells = Math.ceil((firstDay + daysInMonth) / 7) * 7;
  for (let i = 1; i <= totalCells - firstDay - daysInMonth; i++) {
    const el = document.createElement('div');
    el.className = 'cal-day other-month';
    el.innerHTML = `<div class="day-num">${i}</div>`;
    grid.appendChild(el);
  }

  renderUpcoming();
}

function renderUpcoming() {
  const now = new Date(); now.setHours(0,0,0,0);
  const upcoming = EVENTS.filter(e => e.date && new Date(e.date) >= now).slice(0, 4);
  const list = document.getElementById('upcoming-list');

  if (!upcoming.length) {
    list.innerHTML = '<div class="empty-state">No upcoming events</div>';
    return;
  }

  list.innerHTML = upcoming.map(e => {
    const d = new Date(e.date);
    const typeColors = {
      meeting:  ['#FFF3CC','#7A5500'],
      event:    ['#E6F1FB','#185FA5'],
      deadline: ['#FCEBEB','#A32D2D'],
    };
    const [bg, tc] = typeColors[e.type] ?? typeColors.meeting;
    return `<div class="event-row">
      <div class="event-date-box">
        <div class="eday">${d.getDate()}</div>
        <div class="emon">${months[d.getMonth()].slice(0,3)}</div>
      </div>
      <div class="event-info">
        <div class="event-name">${e.title}</div>
        <div class="event-meta">${e.time}</div>
      </div>
      <span class="ev-tag" style="background:${bg};color:${tc}">${e.type}</span>
    </div>`;
  }).join('');
}

async function openQRModal(eventId, title) {
  const res = await fetch(`/api/events/${eventId}/qr`);
  if (!res.ok) return;
  const { qr } = await res.json();
  document.getElementById('modal-event-title').textContent = title;
  document.getElementById('modal-qr-img').src = qr;
  document.getElementById('qr-modal').classList.remove('hidden');
}

document.getElementById('prev-month').addEventListener('click', () => {
  viewMonth--; if (viewMonth < 0) { viewMonth = 11; viewYear--; }
  renderCalendar();
});
document.getElementById('next-month').addEventListener('click', () => {
  viewMonth++; if (viewMonth > 11) { viewMonth = 0; viewYear++; }
  renderCalendar();
});
document.getElementById('modal-close-btn').addEventListener('click', () => {
  document.getElementById('qr-modal').classList.add('hidden');
});
document.getElementById('qr-modal').addEventListener('click', e => {
  if (e.target === e.currentTarget) e.currentTarget.classList.add('hidden');
});

renderCalendar();

// ── Event creation ────────────────────────────────────────────
if (isOfficer) {
  document.getElementById('open-event-modal')?.addEventListener('click', () => {
    document.getElementById('event-modal').classList.remove('hidden');
  });
  document.getElementById('close-event-modal')?.addEventListener('click', () => {
    document.getElementById('event-modal').classList.add('hidden');
  });
  document.getElementById('event-modal')?.addEventListener('click', e => {
    if (e.target === e.currentTarget) e.currentTarget.classList.add('hidden');
  });

  document.getElementById('submit-event')?.addEventListener('click', async () => {
    const errEl = document.getElementById('ev-error');
    errEl.classList.add('hidden');

    const title    = document.getElementById('ev-title').value.trim();
    const start    = document.getElementById('ev-start').value;
    const end      = document.getElementById('ev-end').value;
    const desc     = document.getElementById('ev-desc').value.trim();
    const location = document.getElementById('ev-location').value.trim();
    const category = document.getElementById('ev-category').value;
    const password = document.getElementById('ev-password').value.trim();

    if (!title || !start) {
      errEl.textContent = 'Title and start time are required.';
      errEl.classList.remove('hidden');
      return;
    }

    const btn = document.getElementById('submit-event');
    btn.disabled = true; btn.textContent = 'Creating…';

    const res = await fetch('/api/events/create', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ title, start_time: start, end_time: end || null, description: desc, location, category, password }),
    });

    btn.disabled = false; btn.textContent = 'Create';

    if (!res.ok) {
      const { error } = await res.json();
      errEl.textContent = error ?? 'Failed to create event.';
      errEl.classList.remove('hidden');
      return;
    }

    const { data } = await res.json();
    EVENTS.push({
      ...data,
      date: data.start_time.split('T')[0],
      time: new Date(data.start_time).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) +
        (data.location ? ' · ' + data.location : ''),
      type: data.category || 'meeting',
    });

    document.getElementById('event-modal').classList.add('hidden');
    ['ev-title','ev-start','ev-end','ev-desc','ev-location','ev-password'].forEach(id => {
      const el = document.getElementById(id); if (el) el.value = '';
    });
    document.getElementById('ev-category').value = 'meeting';
    renderCalendar();
  });
}
</script>
