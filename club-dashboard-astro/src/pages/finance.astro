---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { requireAuth } from '../lib/auth';
import { supabaseAdmin } from '../lib/supabase';

const user = await requireAuth(Astro.request, Astro.response.headers, Astro.redirect);
const isOfficer = ['admin', 'treasurer'].includes(user.role);

// Budgets with category info
const { data: budgets } = await supabaseAdmin
  .from('budgets')
  .select('id, name, amount, spent, category_id, starts_at, ends_at, categories(name)')
  .order('created_at', { ascending: false });

// Categories for forms
const { data: categories } = await supabaseAdmin
  .from('categories')
  .select('id, name, slug')
  .eq('is_active', true)
  .order('name');

// Transactions — officers see all, members see own
let txQuery = supabaseAdmin
  .from('transactions')
  .select('id, amount, description, merchant, status, created_at, category_id, user_id, categories(name), profiles(name, email)')
  .order('created_at', { ascending: false })
  .limit(100);

if (!isOfficer) txQuery = txQuery.eq('user_id', user.id);
const { data: transactions } = await txQuery;

const budgetsJson      = JSON.stringify(budgets ?? []);
const categoriesJson   = JSON.stringify(categories ?? []);
const transactionsJson = JSON.stringify(transactions ?? []);

// Compute totals
const totalBudgeted = (budgets ?? []).reduce((s, b) => s + Number(b.amount), 0);
const totalSpent    = (transactions ?? [])
  .filter(t => t.status === 'approved')
  .reduce((s, t) => s + Number(t.amount), 0);
const pendingCount  = (transactions ?? []).filter(t => t.status === 'pending').length;
---
<DashboardLayout title="Finance" subtitle={`Spring 2026 · ${isOfficer ? 'Officer View' : 'Member View'}`} user={user}>

  <!-- Summary stats -->
  <div class="stats-row" style="margin-bottom:20px">
    <div class="stat-box">
      <div class="stat-num">${totalBudgeted.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</div>
      <div class="stat-lbl">Total Budgeted</div>
    </div>
    <div class="stat-box">
      <div class="stat-num">${totalSpent.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</div>
      <div class="stat-lbl">Approved Spend</div>
    </div>
    <div class="stat-box">
      <div class="stat-num">{pendingCount}</div>
      <div class="stat-lbl">Pending Review</div>
    </div>
  </div>

  <!-- Budgets -->
  <div class="page-header">
    <div class="section-label">Budgets</div>
    {isOfficer && (
      <button class="add-btn" id="open-budget-modal">+ New Budget</button>
    )}
  </div>

  <div class="budget-grid" id="budget-grid">
    {(budgets ?? []).length === 0 ? (
      <div class="empty-state" style="grid-column:1/-1">No budgets yet.</div>
    ) : (budgets ?? []).map(b => {
      const pct = Math.min(100, Math.round((Number(b.spent) / Number(b.amount)) * 100));
      const over = Number(b.spent) > Number(b.amount);
      return (
        <div class="budget-card">
          <div class="budget-card-name">{(b.categories as any)?.name ?? 'Unknown'}</div>
          <div class="budget-card-amt">${Number(b.amount).toLocaleString('en-US', { minimumFractionDigits: 2 })}</div>
          <div class="budget-card-sub">{b.name} · ${Number(b.spent).toFixed(2)} spent ({pct}%)</div>
          <div class="budget-bar-wrap">
            <div class={`budget-bar-fill${over ? ' over' : ''}`} style={`width:${pct}%`}></div>
          </div>
        </div>
      );
    })}
  </div>

  <!-- Transactions -->
  <div class="page-header" style="margin-top:24px">
    <div class="section-label">Transactions</div>
    <button class="add-btn" id="open-tx-modal">+ Submit Expense</button>
  </div>

  <div id="tx-filter-row" style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap">
    <select class="form-select" id="tx-status-filter" style="width:auto;font-size:12px;padding:5px 8px">
      <option value="">All statuses</option>
      <option value="pending">Pending</option>
      <option value="approved">Approved</option>
      <option value="rejected">Rejected</option>
    </select>
    <input class="form-input" id="tx-search" placeholder="Search description…" style="width:200px;font-size:12px;padding:5px 8px"/>
  </div>

  <div style="overflow-x:auto">
    <table class="tx-table" id="tx-table">
      <thead>
        <tr>
          <th>Description</th>
          <th>Category</th>
          <th>Merchant</th>
          <th>Submitted by</th>
          <th>Date</th>
          <th>Amount</th>
          <th>Status</th>
          {isOfficer && <th>Actions</th>}
        </tr>
      </thead>
      <tbody id="tx-tbody"></tbody>
    </table>
  </div>
  <div class="empty-state hidden" id="tx-empty">No transactions found.</div>

  <!-- Submit Expense Modal -->
  <div class="form-modal hidden" id="tx-modal">
    <div class="form-card">
      <div class="form-card-title">Submit Expense</div>
      <div class="form-row">
        <label class="form-label">Description *</label>
        <input class="form-input" id="tx-desc" placeholder="e.g. Snacks for meeting" />
      </div>
      <div class="form-row-2">
        <div class="form-row" style="margin-bottom:0">
          <label class="form-label">Amount ($) *</label>
          <input class="form-input" id="tx-amount" type="number" min="0.01" step="0.01" placeholder="0.00" />
        </div>
        <div class="form-row" style="margin-bottom:0">
          <label class="form-label">Category *</label>
          <select class="form-select" id="tx-category">
            <option value="">Select…</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <label class="form-label">Merchant / Vendor</label>
        <input class="form-input" id="tx-merchant" placeholder="e.g. Costco" />
      </div>
      <div class="form-error hidden" id="tx-error"></div>
      <div class="form-actions">
        <button class="form-cancel" id="close-tx-modal">Cancel</button>
        <button class="form-submit" id="submit-tx">Submit</button>
      </div>
    </div>
  </div>

  <!-- New Budget Modal (officer only) -->
  {isOfficer && (
    <div class="form-modal hidden" id="budget-modal">
      <div class="form-card">
        <div class="form-card-title">Create Budget</div>
        <div class="form-row">
          <label class="form-label">Budget Name *</label>
          <input class="form-input" id="bud-name" placeholder="e.g. Spring Semester 2026" />
        </div>
        <div class="form-row-2">
          <div class="form-row" style="margin-bottom:0">
            <label class="form-label">Amount ($) *</label>
            <input class="form-input" id="bud-amount" type="number" min="1" step="0.01" placeholder="0.00" />
          </div>
          <div class="form-row" style="margin-bottom:0">
            <label class="form-label">Category *</label>
            <select class="form-select" id="bud-category">
              <option value="">Select…</option>
            </select>
          </div>
        </div>
        <div class="form-row-2">
          <div class="form-row" style="margin-bottom:0">
            <label class="form-label">Start Date *</label>
            <input class="form-input" id="bud-start" type="date" />
          </div>
          <div class="form-row" style="margin-bottom:0">
            <label class="form-label">End Date *</label>
            <input class="form-input" id="bud-end" type="date" />
          </div>
        </div>
        <div class="form-error hidden" id="bud-error"></div>
        <div class="form-actions">
          <button class="form-cancel" id="close-budget-modal">Cancel</button>
          <button class="form-submit" id="submit-budget">Create</button>
        </div>
      </div>
    </div>
  )}

</DashboardLayout>

<script define:vars={{ transactionsJson, categoriesJson, isOfficer }}>
let ALL_TX = JSON.parse(transactionsJson);
const CATEGORIES = JSON.parse(categoriesJson);

// Populate category selects
function populateCategorySelects() {
  ['tx-category', 'bud-category'].forEach(id => {
    const el = document.getElementById(id);
    if (!el) return;
    CATEGORIES.forEach(c => {
      const opt = document.createElement('option');
      opt.value = c.id;
      opt.textContent = c.name;
      el.appendChild(opt);
    });
  });
}
populateCategorySelects();

// ── Render transactions table ─────────────────────────────────
function renderTx() {
  const statusFilter = document.getElementById('tx-status-filter')?.value ?? '';
  const search = (document.getElementById('tx-search')?.value ?? '').toLowerCase();

  const filtered = ALL_TX.filter(t => {
    if (statusFilter && t.status !== statusFilter) return false;
    if (search && !t.description.toLowerCase().includes(search) && !(t.merchant ?? '').toLowerCase().includes(search)) return false;
    return true;
  });

  const tbody = document.getElementById('tx-tbody');
  const empty = document.getElementById('tx-empty');

  if (!filtered.length) {
    tbody.innerHTML = '';
    empty.classList.remove('hidden');
    return;
  }
  empty.classList.add('hidden');

  tbody.innerHTML = filtered.map(t => {
    const cat = t.categories?.name ?? '—';
    const who = t.profiles?.name ?? t.profiles?.email ?? '—';
    const date = new Date(t.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    const amt = `$${Number(t.amount).toFixed(2)}`;
    const actions = isOfficer && t.status === 'pending'
      ? `<td><div class="tx-actions">
          <button class="tx-btn approve" data-id="${t.id}" data-action="approved">Approve</button>
          <button class="tx-btn reject"  data-id="${t.id}" data-action="rejected">Reject</button>
         </div></td>`
      : isOfficer
      ? `<td><div class="tx-actions">
          <button class="tx-btn delete" data-id="${t.id}" data-action="delete">Delete</button>
         </div></td>`
      : '';
    return `<tr>
      <td>${t.description}</td>
      <td>${cat}</td>
      <td>${t.merchant ?? '—'}</td>
      <td>${who}</td>
      <td>${date}</td>
      <td class="tx-amount negative">${amt}</td>
      <td><span class="tx-status ${t.status}">${t.status}</span></td>
      ${actions}
    </tr>`;
  }).join('');

  // Wire up action buttons
  tbody.querySelectorAll('[data-action]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const { id, action } = btn.dataset;
      if (action === 'delete') {
        if (!confirm('Delete this transaction?')) return;
        await fetch(`/api/finance/transactions/${id}`, { method: 'DELETE' });
        ALL_TX = ALL_TX.filter(t => t.id !== id);
      } else {
        const res = await fetch(`/api/finance/transactions/${id}`, {
          method: 'PATCH',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ status: action }),
        });
        if (res.ok) {
          const { data } = await res.json();
          const idx = ALL_TX.findIndex(t => t.id === id);
          if (idx >= 0) ALL_TX[idx] = { ...ALL_TX[idx], status: data.status };
        }
      }
      renderTx();
    });
  });
}
renderTx();

document.getElementById('tx-status-filter')?.addEventListener('change', renderTx);
document.getElementById('tx-search')?.addEventListener('input', renderTx);

// ── Submit Expense ────────────────────────────────────────────
function showError(id, msg) {
  const el = document.getElementById(id);
  if (!el) return;
  el.textContent = msg;
  el.classList.remove('hidden');
}
function clearError(id) {
  const el = document.getElementById(id);
  if (el) el.classList.add('hidden');
}

document.getElementById('open-tx-modal')?.addEventListener('click', () => {
  document.getElementById('tx-modal')?.classList.remove('hidden');
});
document.getElementById('close-tx-modal')?.addEventListener('click', () => {
  document.getElementById('tx-modal')?.classList.add('hidden');
  clearError('tx-error');
});
document.getElementById('tx-modal')?.addEventListener('click', e => {
  if (e.target === e.currentTarget) e.currentTarget.classList.add('hidden');
});

document.getElementById('submit-tx')?.addEventListener('click', async () => {
  clearError('tx-error');
  const desc     = document.getElementById('tx-desc').value.trim();
  const amount   = document.getElementById('tx-amount').value;
  const category = document.getElementById('tx-category').value;
  const merchant = document.getElementById('tx-merchant').value.trim();

  if (!desc || !amount || !category) {
    return showError('tx-error', 'Description, amount, and category are required.');
  }

  const btn = document.getElementById('submit-tx');
  btn.disabled = true;
  btn.textContent = 'Submitting…';

  const res = await fetch('/api/finance/transactions', {
    method: 'POST',
    headers: { 'content-type': 'application/json' },
    body: JSON.stringify({ description: desc, amount, category_id: category, merchant }),
  });

  btn.disabled = false;
  btn.textContent = 'Submit';

  if (!res.ok) {
    const { error } = await res.json();
    return showError('tx-error', error ?? 'Failed to submit.');
  }

  const { data } = await res.json();
  // Add with placeholder category/profile names
  const cat = CATEGORIES.find(c => c.id === category);
  ALL_TX.unshift({ ...data, categories: cat ? { name: cat.name } : null, profiles: null });
  document.getElementById('tx-modal').classList.add('hidden');
  ['tx-desc','tx-amount','tx-merchant'].forEach(id => { document.getElementById(id).value = ''; });
  document.getElementById('tx-category').value = '';
  renderTx();
});

// ── Create Budget ─────────────────────────────────────────────
document.getElementById('open-budget-modal')?.addEventListener('click', () => {
  document.getElementById('budget-modal')?.classList.remove('hidden');
});
document.getElementById('close-budget-modal')?.addEventListener('click', () => {
  document.getElementById('budget-modal')?.classList.add('hidden');
  clearError('bud-error');
});
document.getElementById('budget-modal')?.addEventListener('click', e => {
  if (e.target === e.currentTarget) e.currentTarget.classList.add('hidden');
});

document.getElementById('submit-budget')?.addEventListener('click', async () => {
  clearError('bud-error');
  const name     = document.getElementById('bud-name').value.trim();
  const amount   = document.getElementById('bud-amount').value;
  const category = document.getElementById('bud-category').value;
  const start    = document.getElementById('bud-start').value;
  const end      = document.getElementById('bud-end').value;

  if (!name || !amount || !category || !start || !end) {
    return showError('bud-error', 'All fields are required.');
  }

  const btn = document.getElementById('submit-budget');
  btn.disabled = true;
  btn.textContent = 'Creating…';

  const res = await fetch('/api/finance/budgets', {
    method: 'POST',
    headers: { 'content-type': 'application/json' },
    body: JSON.stringify({ name, amount, category_id: category, starts_at: start, ends_at: end }),
  });

  btn.disabled = false;
  btn.textContent = 'Create';

  if (!res.ok) {
    const { error } = await res.json();
    return showError('bud-error', error ?? 'Failed to create budget.');
  }

  // Reload to reflect new budget card
  window.location.reload();
});
</script>
