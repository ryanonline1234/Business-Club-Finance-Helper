---
interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

const navItems = [
  {
    href: '/calendar',
    label: 'Calendar',
    icon: `<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="2" width="14" height="13" rx="2"/><line x1="5" y1="1" x2="5" y2="4"/><line x1="11" y1="1" x2="11" y2="4"/><line x1="1" y1="6" x2="15" y2="6"/></svg>`,
  },
  {
    href: '/attendance',
    label: 'Attendance',
    icon: `<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 7a3 3 0 100-6 3 3 0 000 6z"/><path d="M1 14s-1-5 5-5 5 5 5 5"/><path d="M12 6l1.5 1.5L16 5"/></svg>`,
  },
  {
    href: '/members',
    label: 'Members',
    icon: `<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="5" r="3"/><path d="M1 14c0-3 2.5-5 5-5s5 2 5 5"/><circle cx="12" cy="5" r="2"/><path d="M12 10c1.5 0 3 .8 3 3"/></svg>`,
  },
  {
    href: '/announcements',
    label: 'Announcements',
    icon: `<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4h12v7a2 2 0 01-2 2H4a2 2 0 01-2-2V4z"/><path d="M2 4l6 5 6-5"/></svg>`,
  },
];
---
<div class="sidebar">
  <div class="logo">
    <div class="logo-title">Mitty Business Club</div>
    <div class="logo-sub">Officer Portal</div>
  </div>

  {navItems.map(item => (
    <a
      href={item.href}
      class={`nav-item${currentPath.startsWith(item.href) ? ' active' : ''}`}
    >
      <span class="nav-icon" set:html={item.icon} />
      {item.label}
    </a>
  ))}

  <div style="flex:1"></div>

  <div class="sidebar-footer">
    <a href="/api/auth/signout" class="nav-item" style="padding:0;border:none;margin-bottom:8px;font-size:12px;">
      <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M6 2H3a1 1 0 00-1 1v10a1 1 0 001 1h3M10 11l3-3-3-3M13 8H6"/>
      </svg>
      Sign Out
    </a>
  </div>
</div>
